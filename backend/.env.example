# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Kosongkan untuk pakai default
# (quransrt.com + localhost:3000). Tambahkan URL Vercel preview jika perlu.
CORS_ORIGINS=https://quransrt.com,https://www.quransrt.com

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIs...

# ── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=production
